# ── RazinSoft website config ── copy to .env and adjust per environment.

# Laravel API base URL the website talks to. No trailing slash after /api.
# Local dev:  http://127.0.0.1:8000/api
# Production: https://api.yourdomain.com/api
# The @nuxt/image optimiser domain is derived from this host automatically.
NUXT_PUBLIC_API_BASE=http://127.0.0.1:8000/api

# Public site origin used for canonical URLs, sitemap.xml, robots.txt, Open Graph
# tags and JSON-LD. No trailing slash.
SITE_URL=https://razinsoft.com
